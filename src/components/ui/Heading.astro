---
export interface Props {
  as?: "h1" | "h2";
  id?: string;
  underlineColor: string;
}

const { as: Tag = "h2", id, underlineColor } = Astro.props;
---

<Tag
  id={id}
  class={`scroll-mt-24 underline-offset-[8px] md:underline-offset-[12px] transition-all duration-300 underline decoration-12 text-zinc-800 ${underlineColor} pb-4`}
>
  <slot />
</Tag>
