---
import { subDomainInNewTab } from "../../lib/data";

export interface Props {
  href: string;
  src?: string;
  class?: string;
}

const { href, src, class: className } = Astro.props;

const isExternal = href.startsWith("http");
const isInternal = href.endsWith(subDomainInNewTab);
const target = isExternal && !isInternal ? "_blank" : "_self";
const rel = isExternal && !isInternal ? "noopener noreferrer" : undefined;
---

<a
  href={href}
  {target}
  {rel}
  class={`inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-lg text-sm font-semibold
    transition-all cursor-pointer h-10 px-6 py-2.5 text-zinc-700 border-2 border-zinc-400
    shadow-[0_6px_0_rgb(161,161,170)] active:shadow-[0_2px_0px_rgb(161,161,170)] active:translate-y-1
    outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50
    ${className ?? ""}`}
>
  {src && <img class="select-none" alt="" src={src} height={20} width={20} />}
  <slot />
</a>
